// NOTE: For Vercel deployment with PostgreSQL, change provider to "postgresql"
// and set DATABASE_URL to your PostgreSQL connection string in Vercel environment variables.
// The model structure is compatible with both SQLite and PostgreSQL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WorkOrder {
  id            String   @id
  otId          String
  activities    String   // JSON array stored as string
  collaborators String   // JSON array stored as string
  zoneName      String
  description   String   @default("")
  status        String   @default("Pendiente")
  photosBefore  String   @default("[]") // JSON array of base64 strings
  photosAfter   String   @default("[]") // JSON array of base64 strings
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
