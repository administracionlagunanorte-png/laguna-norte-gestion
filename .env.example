# Neon PostgreSQL connection URL (Prisma)
# Pooled connection (for Prisma Client in app runtime - serverless friendly)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&connect_timeout=10

# Direct connection (for Prisma Migrate / db push - no pooler)
DIRECT_URL=postgresql://user:password@ep-xxx.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&connect_timeout=10
